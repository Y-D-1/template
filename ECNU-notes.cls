\cs_new_protected:Npn \yd_index_sortkey_set:n #1
	{
		\tl_clear:N \l__yd_index_key_tl
		\tl_map_inline:nn {#1} { \yd_index_sortkey_char:n {##1} }
		\tl_if_empty:NT \l__yd_index_key_tl
			{ \tl_set:Nx \l__yd_index_key_tl { \detokenize{#1} } }
	}

\cs_new_protected:Npn \yd_index_sortkey_char:n #1
	{
		\token_if_cs:NTF #1
			{ }
			{
				\token_if_group_begin:NTF #1
					{ }
					{
						\token_if_group_end:NTF #1
							{ }
							{
								\tl_if_blank:nTF {#1}
									{ }
									{
										\int_set:Nn \l__yd_index_code_int { \__xpinyin_char_to_unicode:n {#1} }
										\tl_if_exist:cTF { c__xpinyin_\int_use:N \l__yd_index_code_int _tl }
											{
												\tl_set:Nx \l__yd_index_py_tl
													{ \use:c { c__xpinyin_\int_use:N \l__yd_index_code_int _tl } }
												\tl_put_right:Nx \l__yd_index_key_tl
													{ \tl_lower_case:n { \tl_head:V \l__yd_index_py_tl } }
											}
											{
												\regex_match:nnTF { [A-Za-z0-9] } {#1}
													{ \tl_put_right:Nx \l__yd_index_key_tl { \tl_lower_case:n {#1} } }
													{ }
											}
									}
							}
					}
			}
	}

\cs_new_protected:Npn \yd_index_auto:n #1
	{
		\yd_index_sortkey_set:n {#1}
		\exp_args:Nx \index { \tl_use:N \l__yd_index_key_tl @ \detokenize{#1} }
	}

\cs_new_protected:Npn \yd_index_manual:nn #1#2
	{ \exp_args:Nx \index { \tl_lower_case:n {#1} @ \detokenize{#2} } }

\NewDocumentCommand{\ydindexauto}{m}{\yd_index_auto:n{#1}}
\NewDocumentCommand{\ydindexmanual}{m m}{\yd_index_manual:nn{#1}{#2}}
